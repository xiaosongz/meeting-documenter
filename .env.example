# Meeting Documenter — environment template
# Copy to .env and fill in. .env is gitignored.

# ─── Required ────────────────────────────────────────────────────────────────

# Google AI Studio API key for Gemini transcription
# Get one at https://aistudio.google.com/apikey
# (Pipeline accepts GEMINI_API_KEY as a fallback; either works.)
# Quote the value if it contains shell metachars (<, >, *, &, etc.)
GOOGLE_API_KEY="your-key-here"

# Notes / vault root — every other path defaults under this
VAULT_PATH="/path/to/your/vault"

# ─── Optional — override if your vault layout differs from defaults ─────────

# MEETING_NOTES_DIR=${VAULT_PATH}/MeetingNotes
# MEETING_RAW_DIR=${MEETING_NOTES_DIR}/raw
# MEETING_RECORDINGS_DIR=${MEETING_NOTES_DIR}/recordings
# DAILY_NOTES_DIR=${VAULT_PATH}/DailyNotes
# PROJECTS_DIR=${VAULT_PATH}/Projects
# MEETING_AUDIO_BACKUP_DIR=$HOME/audio-backups/meetings

# ─── Optional — override conventions if your note system differs ────────────

# Daily note path format (strftime, relative to DAILY_NOTES_DIR)
# Examples: "%Y-%m-%d.md" (flat) | "Journal/%Y/%Y-%m-%d.md"
# DAILY_NOTE_PATH_FORMAT="%Y/%m-%B/%Y-%m-%d.md"

# Per-project reference-note subdir under PROJECTS_DIR/{Name}/.
# Set to empty string to write refs directly into the project root.
# PROJECT_MEETING_SUBDIR="Meeting"

# Output link form: wikilink (Obsidian) | markdown | plain
# LINK_STYLE="wikilink"
